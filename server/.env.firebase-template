# ============================================
# Firebase Admin SDK Configuration
# ============================================
# 
# INSTRUCTIONS:
# 1. Go to: https://console.firebase.google.com/project/lekki-stays/settings/serviceaccounts/adminsdk
# 2. Click "Generate new private key"
# 3. Download the JSON file
# 4. Copy the values from the JSON file to the variables below
# 5. Add these lines to your server/.env file
#
# ============================================

# Copy from JSON: "project_id"
FIREBASE_PROJECT_ID=lekki-stays

# Copy from JSON: "private_key" (keep the quotes and \n characters!)
# Example: "-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBg...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Copy from JSON: "client_email"
# Example: firebase-adminsdk-xxxxx@lekki-stays.iam.gserviceaccount.com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@lekki-stays.iam.gserviceaccount.com

# ============================================
# IMPORTANT NOTES:
# ============================================
# 
# 1. Keep the quotes around FIREBASE_PRIVATE_KEY
# 2. Keep the \n characters (they represent newlines)
# 3. Copy the ENTIRE private key including BEGIN and END lines
# 4. Don't commit the service account JSON file to Git
# 5. Don't commit .env file to Git (it's already in .gitignore)
#
# ============================================

# Server Configuration
NODE_ENV=production
PORT=3000

# WhatsApp Configuration (Your WhatsApp number with country code)
HOST_WHATSAPP_NUMBER=+2349039269846

# Base URL Configuration (Update this to your Vercel domain)
BASE_URL=https://your-app-name.vercel.app

# Bank Details (Update with your real bank information)
BANK_NAME=Your Bank Name
BANK_ACCOUNT_NUMBER=Your Account Number
BANK_ACCOUNT_NAME=Your Account Name

# Admin Security Key (CHANGE THIS TO YOUR OWN SECRET STRING)
ADMIN_KEY=your-super-secret-admin-key-here

# Database Configuration
DB_PATH=./data/lekki-stays.db

# Security Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Monitoring Configuration
ENABLE_PERFORMANCE_MONITORING=true
LOG_LEVEL=info
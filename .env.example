# ============================================
# LEKKI STAYS - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!
# ============================================

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from: https://supabase.com/dashboard
# → Your Project → Settings → API

# Your Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Public anon key (safe to use in frontend)
SUPABASE_ANON_KEY=your_anon_key_here

# Service role key (NEVER expose in frontend!)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# WHATSAPP CONFIGURATION
# ============================================
# Your WhatsApp number for booking notifications
# Format: Country code + number (no spaces, no +)
# Example: 2348012345678 for Nigeria
HOST_WHATSAPP_NUMBER=2348012345678

# ============================================
# NODE ENVIRONMENT
# ============================================
# Set to 'production' for deployment
# Set to 'development' for local testing
NODE_ENV=development

# ============================================
# OPTIONAL: CUSTOM CONFIGURATION
# ============================================
# Add any custom environment variables below
# PORT=3000
# API_VERSION=v1
